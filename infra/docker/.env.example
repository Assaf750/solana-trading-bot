# Local DEV ONLY — DUMMY values. Copy to `.env` (gitignored) to override defaults.
# These are NON-production, NON-secret local development credentials.
# NEVER put real secrets / private keys / seed phrases / API keys / RPC endpoints here.

# --- PostgreSQL ---
POSTGRES_USER=soltrade
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=soltrade_dev
POSTGRES_PORT=5432

# --- ClickHouse ---
CLICKHOUSE_DB=soltrade_dev
CLICKHOUSE_USER=soltrade
CLICKHOUSE_PASSWORD=devpassword
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# --- Redis ---
REDIS_PORT=6379

# --- App storage backend (apps/server — ADR-0001 Phase 4) ---
# STORAGE_BACKEND selects where decision-ledger / positions / audit persist:
#   json     = local JSON files in data/ (DEFAULT — safe, no Postgres required)
#   postgres = the PostgreSQL datastore above (run `npm run db:postgres:migrate` first)
STORAGE_BACKEND=json
# When STORAGE_BACKEND=postgres, set POSTGRES_URL (derived from the PostgreSQL creds above):
# POSTGRES_URL=postgres://soltrade:devpassword@127.0.0.1:5432/soltrade_dev
# (or set PGHOST / PGPORT / PGUSER / PGPASSWORD / PGDATABASE individually)
# Optional local smoke test against a running Postgres:
# RUN_POSTGRES_SMOKE=1 POSTGRES_URL=... npm run smoke:postgres
