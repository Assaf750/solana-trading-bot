# Local DEV ONLY — DUMMY values. Copy to `.env` (gitignored) to override defaults.
# These are NON-production, NON-secret local development credentials.
# NEVER put real secrets / private keys / seed phrases / API keys / RPC endpoints here.

# --- PostgreSQL ---
POSTGRES_USER=soltrade
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=soltrade_dev
POSTGRES_PORT=5432

# --- ClickHouse ---
CLICKHOUSE_DB=soltrade_dev
CLICKHOUSE_USER=soltrade
CLICKHOUSE_PASSWORD=devpassword
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# --- Redis ---
REDIS_PORT=6379

# --- App storage backend (apps/server — ADR-0001 Phase 4) ---
# STORAGE_BACKEND selects where decision-ledger / positions / audit persist:
#   json     = local JSON files in data/ (DEFAULT — safe, no Postgres required)
#   postgres = the PostgreSQL datastore above (run `npm run db:postgres:migrate` first)
STORAGE_BACKEND=json
# When STORAGE_BACKEND=postgres, set POSTGRES_URL (derived from the PostgreSQL creds above):
# POSTGRES_URL=postgres://soltrade:devpassword@127.0.0.1:5432/soltrade_dev
# (or set PGHOST / PGPORT / PGUSER / PGPASSWORD / PGDATABASE individually)
# Optional local smoke test against a running Postgres:
# RUN_POSTGRES_SMOKE=1 POSTGRES_URL=... npm run smoke:postgres

# --- Diagnostic execution adapter (apps/server — ADR-0001 Phase 5A) ---
# DIAGNOSTIC_BACKEND selects the pre-flight diagnostic surface (read-only; never trades):
#   legacy  = no diagnostic adapter wired (DEFAULT — paper-engine behavior unchanged)
#   package = wire @soltrade/execution DiagnosticExecutionAdapter + POST /api/diagnostics/run
DIAGNOSTIC_BACKEND=legacy

# --- App hot-state backend (apps/server — ADR-0001 Phase 6A) ---
# HOT_STATE_BACKEND selects the cache/locks/cursors/rate-limits layer. Hot-state is CACHE ONLY —
# Postgres/JSON stays the source of truth and every entry is rebuildable:
#   memory = in-process cache (DEFAULT — no Redis required)
#   redis  = the Redis datastore above (set REDIS_URL)
HOT_STATE_BACKEND=memory
# When HOT_STATE_BACKEND=redis, set REDIS_URL (derived from REDIS_PORT above):
# REDIS_URL=redis://127.0.0.1:6379
# (or set REDIS_HOST / REDIS_PORT individually)
# Optional local smoke test against a running Redis:
# RUN_REDIS_SMOKE=1 REDIS_URL=... npm run smoke:redis

# --- App event sink (apps/server — ADR-0001 Phase 7A) ---
# EVENT_SINK_BACKEND selects the append-only analytics/events sink. ClickHouse is analytics ONLY —
# Postgres/JSON stays the operational source of truth; losing it never affects trading:
#   none      = events are dropped (DEFAULT — no ClickHouse required)
#   clickhouse = the ClickHouse datastore above (run `npm run db:clickhouse:migrate` first)
EVENT_SINK_BACKEND=none
# When EVENT_SINK_BACKEND=clickhouse, set CLICKHOUSE_URL (derived from the ClickHouse creds above):
# CLICKHOUSE_URL=http://127.0.0.1:8123
# (or set CLICKHOUSE_HOST / CLICKHOUSE_HTTP_PORT; auth via CLICKHOUSE_USER / CLICKHOUSE_PASSWORD / CLICKHOUSE_DB)
# Optional local smoke test against a running ClickHouse:
# RUN_CLICKHOUSE_SMOKE=1 CLICKHOUSE_URL=... npm run smoke:clickhouse

# --- Signing / execution boundary (ADR-0001 Phase Rust-1) ---
# The OFFICIAL signing boundary is the Rust services/hot-executor. Build it (`cargo build --release` in
# services/hot-executor) and point HOT_EXECUTOR_BIN at the binary to activate it. When set, the
# live-executor prefers it (config execution.signer_backend defaults to 'rust'); ANY failure falls back
# to the in-process signer (fail-safe), so live signing is never blocked. Leave unset for the in-process
# dev/local signer. This is NOT a gate — runtime readiness reports it as available / not_configured /
# unavailable (informational only).
# HOT_EXECUTOR_BIN=/abs/path/to/services/hot-executor/target/release/hot-executor

# --- Full local stack (opt-in; defaults above stay safe) ---
# To run the whole Live-First stack locally (Postgres + Redis + ClickHouse + server + UI), follow
# docs/runbooks/local-full-stack.md. Combined reachability check (opt-in; sends no transaction):
# RUN_FULL_STACK_SMOKE=1 SOLTRADE_BASE_URL=http://127.0.0.1:8787 npm run smoke:full-stack
